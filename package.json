{
  "name": "puppeteer-debugger",
  "version": "1.0.0",
  "description": "A modern web UI debugger for Chrome DevTools Protocol with dual-mode JavaScript execution",
  "main": "server/index.js",
  "scripts": {
    "start": "bun run src/server/index.ts",
    "dev": "bun run --watch src/server/index.ts",
    "tscheck": "bunx tsc --noEmit"
  },
  "keywords": [
    "puppeteer",
    "chrome",
    "debugger",
    "cdp",
    "websocket",
    "devtools",
    "javascript",
    "web-debugging"
  ],
  "author": "Puppeteer Debugger Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/long369486562/puppeteer-debugger.git"
  },
  "homepage": "https://github.com/long369486562/puppeteer-debugger#readme",
  "bugs": {
    "url": "https://github.com/long369486562/puppeteer-debugger/issues"
  },
  "engines": {
    "bun": "^1.0.0"
  },
  "dependencies": {
    "puppeteer-core": "^21.11.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/ws": "^8.18.1"
  }
}